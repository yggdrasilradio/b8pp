1DIMX(5),Y(5)
10PRINT"How many waves (1-5)";\INPUTN\IFN<1THEN10\IFN>5THEN10\RANDOM
11FORI=1TON\X(I)=INT(70*RND(0))+1\Y(I)=INT(20*RND(0))+1\NEXTI
12FORY=1TO20\FORX=1TO70\A=0\FORI=1TON\X2=X-X(I)\Y2=Y-Y(I)
13D=SQR(X2^2+Y2^2)/2\A=A+INT(4*SIN(D))+4+1\NEXTI\V=INT(A/N)\GOSUB100
14NEXTX\PRINT\NEXTY\STOP
100ONVGOTO101,102,103,104,105,106,107,108
